/* ===== Sections ===== */

.section{
padding:80px 20px;
max-width:1100px;
margin:auto;
}

.section h2{
text-align:center;
font-size:38px;
margin-bottom:40px;
color:#38bdf8;
}

/* ===== Cards ===== */

.cards{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:25px;
}

.card{
background:rgba(255,255,255,.08);
backdrop-filter:blur(15px);
border:1px solid rgba(255,255,255,.1);
border-radius:20px;
padding:25px;
transition:.35s;
box-shadow:0 10px 30px rgba(0,0,0,.25);
}

.card:hover{
transform:translateY(-10px);
box-shadow:0 20px 40px rgba(56,189,248,.25);
border-color:#38bdf8;
}

.card h3{
margin-bottom:15px;
color:#38bdf8;
font-size:22px;
}

.card p{
color:#d1d5db;
line-height:1.8;
}

/* ===== Contact Cards ===== */

#contact .card{
text-decoration:none;
color:#fff;
text-align:center;
font-size:18px;
font-weight:600;
display:flex;
justify-content:center;
align-items:center;
min-height:90px;
}

#contact .card:hover{
background:#38bdf8;
color:#fff;
}
